<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/slot_bt.xml
     One BT Ducky payload slot row.
     Included 4× in activity_main.xml as slotBt0…slotBt3.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="10dp"
    android:background="#0E0B16"
    android:padding="10dp">

    <!-- Row 1: label + edit button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvBtSlotLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BT SLOT 1"
            android:textColor="#A020F0"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textStyle="bold"/>

        <!-- Edit payload -->
        <Button
            android:id="@+id/btnBtEdit"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="✎"
            android:textColor="#A020F0"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:backgroundTint="#150E20"
            android:padding="0dp"
            android:layout_marginEnd="4dp"/>

        <!-- Execute -->
        <Button
            android:id="@+id/btnBtExec"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="▶ EXEC"
            android:textColor="#060810"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:backgroundTint="#A020F0"
            android:paddingHorizontal="10dp"
            android:layout_marginEnd="4dp"/>

        <!-- Clear -->
        <Button
            android:id="@+id/btnBtClear"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="✕"
            android:textColor="#5A6A7A"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:backgroundTint="#0C0E18"
            android:paddingHorizontal="10dp"/>
    </LinearLayout>

    <!-- Row 2: payload preview -->
    <TextView
        android:id="@+id/tvBtSlotData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="— EMPTY"
        android:textColor="#2A2040"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:background="#0A0812"
        android:padding="8dp"
        android:singleLine="true"
        android:ellipsize="end"/>

</LinearLayout>